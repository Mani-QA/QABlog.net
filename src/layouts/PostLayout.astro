---
import BaseLayout from './BaseLayout.astro';

interface Props {
	frontmatter: {
		title: string;
		description: string;
		pubDate: Date | string;
		author: string;
		tags: string[];
		category: string;
		coverImage?: string;
	};
}

const { frontmatter } = Astro.props;
const pubDateObj = new Date(frontmatter.pubDate);
const formattedDate = pubDateObj.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const categoryPath = `/${frontmatter.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
---
<BaseLayout
	title={`${frontmatter.title} - QA Blog`}
	description={frontmatter.description}
	ogType="article"
	ogImage={frontmatter.coverImage}
	pubDate={pubDateObj}
	category={frontmatter.category}
	schemaType="BlogPosting"
>
	<div class="post-content">
		<br />
		<h2>{frontmatter.title}</h2>
		<p class="post-meta">Posted on {formattedDate} in <a href={categoryPath}>{frontmatter.category}</a> by {frontmatter.author}</p>
		
		{frontmatter.coverImage && (
			<span class="image main">
				<img src={frontmatter.coverImage} alt={frontmatter.title} />
			</span>
		)}

		<article class="prose">
			<slot />
		</article>

		<hr />

		<!-- E-E-A-T Author Trust Bio Card component -->
		<div class="box author-bio">
			<div class="author-avatar">
				<span class="avatar-fallback"
					style="display:flex; align-items:center; justify-content:center; width:4.5em; height:4.5em; border-radius:50%; background-color:#f56a6a; color:#ffffff; font-family:'Roboto Slab',serif; font-weight:700; font-size:1em; border:solid 2px #f56a6a;">MG</span>
			</div>
			<div class="author-details">
				<h4>About the Author: {frontmatter.author}</h4>
				<p>Mani is an expert systems architect and quality assurance engineer specializing in enterprise-grade test automation architectures, CI/CD reliability, and high-performance load testing.</p>
			</div>
		</div>
	</div>
</BaseLayout>

<style is:global>
	/* Constraint the max-width and improve spacing for readability */
	.post-content {
		max-width: 800px;
		margin: 0 auto;
		text-align: left !important;
	}

	.post-content h2 {
		font-size: 2.4em;
		line-height: 1.25;
		margin-bottom: 0.3em;
		font-weight: 700;
		color: #3d4449;
		font-family: "Roboto Slab", serif;
	}

	.post-meta {
		font-size: 0.95em;
		color: #7f888f;
		margin-bottom: 2em;
	}

	/* Article body spacing & layout formatting */
	.prose {
		font-size: 1.15rem;
		line-height: 1.85;
		color: #333333;
		font-family: "Open Sans", sans-serif;
	}

	.prose p {
		margin: 0 0 1.8em 0;
	}

	.prose h3 {
		font-size: 1.6em;
		font-weight: 700;
		color: #3d4449;
		margin-top: 2.2em;
		margin-bottom: 0.7em;
		font-family: "Roboto Slab", serif;
		line-height: 1.3;
		border-bottom: solid 1px rgba(210, 215, 217, 0.5);
		padding-bottom: 0.35em;
	}

	.prose h4 {
		font-size: 1.25em;
		font-weight: 700;
		color: #3d4449;
		margin-top: 1.8em;
		margin-bottom: 0.6em;
		font-family: "Roboto Slab", serif;
		line-height: 1.3;
	}

	.prose ul {
		list-style-type: disc !important;
		margin: 0 0 1.8em 0;
		padding-left: 2em !important;
	}

	.prose ol {
		list-style-type: decimal !important;
		margin: 0 0 1.8em 0;
		padding-left: 2em !important;
	}

	.prose li {
		margin-bottom: 0.5em;
		padding-left: 0.25em;
	}

	.prose strong {
		color: #2c3e50;
		font-weight: 700;
	}

	.prose blockquote {
		border-left: solid 4px #f56a6a;
		font-style: italic;
		margin: 1.8em 0;
		padding: 0.6em 0 0.6em 1.5em;
		background: rgba(245, 106, 106, 0.02);
		color: #555;
	}
</style>
