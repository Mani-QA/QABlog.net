---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
	title: string;
	description: string;
	ogType?: 'website' | 'article';
	ogImage?: string;
	pubDate?: Date;
	category?: string;
	schemaType?: 'WebSite' | 'CollectionPage' | 'BlogPosting';
}

const {
	title,
	description,
	ogType = 'website',
	ogImage = '/images/hero_visual.png',
	pubDate,
	category,
	schemaType = 'WebSite'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const currentPath = Astro.url.pathname;

// Schema JSON-LD builder
let schemaJson: any = null;

if (schemaType === 'WebSite') {
	schemaJson = {
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "QABlog.net",
		"description": "Your complete guide to software quality assurance, test automation, performance engineering, and continuous testing.",
		"url": Astro.site?.href,
		"inLanguage": "en",
		"publisher": {
			"@type": "Organization",
			"name": "QABlog.net",
			"url": Astro.site?.href
		}
	};
} else if (schemaType === 'CollectionPage') {
	schemaJson = {
		"@context": "https://schema.org",
		"@type": "CollectionPage",
		"name": title,
		"description": description,
		"url": canonicalUrl,
		"isPartOf": {
			"@type": "WebSite",
			"name": "QABlog.net",
			"url": Astro.site?.href
		},
		"inLanguage": "en"
	};
} else if (schemaType === 'BlogPosting') {
	schemaJson = {
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		"headline": title,
		"description": description,
		"datePublished": pubDate ? pubDate.toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
		"dateModified": pubDate ? pubDate.toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
		"author": {
			"@type": "Person",
			"name": "Mani G."
		},
		"publisher": {
			"@type": "Organization",
			"name": "QABlog.net",
			"url": Astro.site?.href
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": canonicalUrl
		},
		"inLanguage": "en"
	};
	if (category) {
		schemaJson.articleSection = category;
	}
}
---
<!DOCTYPE HTML>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
	<link rel="canonical" href={canonicalUrl} />
	<link rel="sitemap" type="application/xml" href="/sitemap.xml" />
	<meta name="robots" content="index, follow" />
	
	<!-- Tailwind and Global Stylesheet -->
	<link rel="stylesheet" href="/style.css" />

	<!-- OpenGraph Tags -->
	<meta property="og:title" content={title} />
	<meta property="og:type" content={ogType} />
	<meta property="og:url" content={canonicalUrl} />
	<meta property="og:site_name" content="QABlog.net" />
	<meta property="og:description" content={description} />
	<meta property="og:locale" content="en_US" />
	<meta property="og:image" content={new URL(ogImage, Astro.site).href} />

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

	{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
	{category && <meta property="article:section" content={category} />}

	{schemaJson && (
		<script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
	)}
</head>
<body class="is-loading">
	<!-- Scroll Reading Progress Indicator -->
	<div id="reading-progress"></div>

	<!-- Sticky Social Sharing Drawer (for blog posts) -->
	{ogType === 'article' && (
		<div class="share-bar">
			<a href={`https://twitter.com/share?url=${encodeURIComponent(canonicalUrl)}&text=${encodeURIComponent(title)}`}
				class="icon fa-twitter" aria-label="Share on Twitter" target="_blank"><span class="label">Twitter</span></a>
			<a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`} class="icon fa-facebook"
				aria-label="Share on Facebook" target="_blank"><span class="label">Facebook</span></a>
			<a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' - ' + canonicalUrl)}`}
				class="icon fa-whatsapp" aria-label="Share on WhatsApp" target="_blank"><span
					class="label">WhatsApp</span></a>
		</div>
	)}

	<div id="wrapper">
		<div id="main">
			<div class="inner">
				<Header />
				<slot />
			</div>
		</div>

		<Sidebar currentPath={currentPath} />
	</div>

	<!-- Template client-side script for menu & progress bar -->
	<script is:inline src="/main.js"></script>
</body>
</html>
